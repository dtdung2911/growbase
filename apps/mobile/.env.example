# Base URL of the GrowBase web API. Trailing slashes are stripped automatically.
# Dev default: your machine's LAN IP so a physical device on the same Wi-Fi can reach it.
# Expo tunnel users: just swap this value for the tunnel URL — no code changes needed.
# Real (non-dev) builds MUST use https — iOS App Transport Security blocks cleartext http.
EXPO_PUBLIC_API_URL=http://<LAN-IP>:3000
